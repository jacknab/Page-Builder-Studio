modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Port Proxy"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 pnpm --filter @workspace/web run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo 'Backend not used'"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Port Proxy"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node proxy.mjs"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23795
externalPort = 80

[[ports]]
localPort = 23796
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 8080

[userenv]

[userenv.shared]
JWT_SECRET = "c192d8e170a553ea5c5999da4a81db8e1ebb29c4093794ec85c6ecfe97c64738459766b8942482eb366ed2f02f42ea4f"

[nix]
channel = "stable-25_05"
